{
  "name": "ai-screen-design",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "dev": "turbo run dev",
    "dev:design": "turbo run dev -F ai-screen-design",
    "build": "turbo run build",
    "prepare": "simple-git-hooks",
    "preinstall": "npx only-allow pnpm",
    "i": "pnpm i --frozen-lockfile"
  },
  "dependencies": {
    "element-plus": "catalog:"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@types/node": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "sass": "catalog:",
    "simple-git-hooks": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-vue-components": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpx lint-staged",
    "commit-msg": "pnpx commitlint --edit"
  },
  "lint-staged": {
    ".{vue,ts,js,tsx,jsx,css,scss,less,json}": [
      "pnpm lint:fix",
      "pnpm fmt"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
